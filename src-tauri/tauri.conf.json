{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "anonpic",
  "version": "0.1.0",
  "identifier": "com.anonpic.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Anonpic",
        "width": 420,
        "height": 320,
        "minWidth": 360,
        "minHeight": 260,
        "center": true,
        "contentProtected": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../ui/logo.png": "logo.png",
      "icons/icon.ico": "icon.ico"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
